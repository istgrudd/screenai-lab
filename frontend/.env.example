# Vite reads this file at build/dev time. Variables must be prefixed
# with VITE_ to be exposed to client code via import.meta.env.

# Base URL for the backend API. Production builds embed this at build
# time, so it must be set on the deploy environment (e.g. Vercel).
# When unset, frontend/src/lib/api.js falls back to the local dev URL
# below — fine for local development, broken in production.
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# Deadline for the current recruitment period (ISO 8601, local time).
# Used by the candidate dashboard countdown.
VITE_RECRUITMENT_DEADLINE=2026-05-31T23:59:59
