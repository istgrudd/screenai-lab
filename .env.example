# =============================================================================
# Local development defaults (uvicorn + vite running on the host)
# =============================================================================

# === Application ===
ENVIRONMENT=development
APP_PORT=8000

# === DeepSeek LLM ===
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Database ===
# Local dev (SQLite):
DATABASE_URL=sqlite:///./data/screenai_lab.db
# Production canonical path is Docker Compose + the `db` service below.
# For non-Docker/manual experiments only, point DATABASE_URL at an operator-managed Postgres host.
# Legacy "postgres://" URLs are normalized to "postgresql://" by backend/database.py.
# DATABASE_URL=postgresql://user:password@host:5432/screenai_lab

# === Vector Store ===
CHROMA_PERSIST_DIR=./backend/vectorstore

# === NER Model ===
NER_MODEL_NAME=ageng-anugrah/indobert-large-p2-finetuned-ner

# === Embedding Model ===
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# === Frontend / CORS ===
# Single origin (used when ALLOWED_ORIGINS is empty):
FRONTEND_URL=http://localhost:5173
# Comma-separated list for production (takes precedence when non-empty):
# ALLOWED_ORIGINS=https://screenai-lab.example.com,https://www.screenai-lab.example.com

# === Auth ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === Frontend (Vite) ===
# Base URL for the backend API the browser talks to. Required for any
# non-local deployment — production builds embed this value at build
# time. Falls back to http://127.0.0.1:8000/api when unset.
# Example (prod separate API domain): VITE_API_BASE_URL=https://screenai-api.example.com/api
# Example (prod same domain, frontend nginx proxies /api): VITE_API_BASE_URL=/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api


# =============================================================================
# Docker / VPS Production (CANONICAL DEPLOYMENT PATH)
# -----------------------------------------------------------------------------
# Copy this block to your VPS .env, fill in the blanks, and run:
#     docker compose up --build -d
#
# Architecture:
#     browser HTTPS -> host Nginx/Caddy -> frontend container :80
#                                             └─ /api -> backend container :8000 -> db :5432
# TLS is handled by the host-level reverse proxy, not inside Docker.
# See docs/DEPLOYMENT.md for the full first-deploy walkthrough.
# =============================================================================

# --- Application ---
# Required: must NOT be "development" for the production startup guards to engage.
# ENVIRONMENT=production

# --- Database ---
# Host is "db" — the Docker Compose service name, NOT localhost.
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB below.
# DATABASE_URL=postgresql://screenai:yourpassword@db:5432/screenai_lab

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# The startup guard will refuse to boot in non-dev if this still starts with the
# "dev-secret" placeholder.
# SECRET_KEY=

# --- CORS ---
# Comma-separated list of frontend origins the browser will use.
# The startup guard will refuse to boot in non-dev if this is empty.
# ALLOWED_ORIGINS=https://your-domain.example

# --- DeepSeek ---
# Server boots without this but evaluation calls will fail.
# DEEPSEEK_API_KEY=

# --- PostgreSQL (consumed by the `db` service AND embedded in DATABASE_URL above) ---
# POSTGRES_USER=screenai
# Set a strong password — used by both the db service and DATABASE_URL above.
# POSTGRES_PASSWORD=
# POSTGRES_DB=screenai_lab

# --- Frontend (Vite build-time) ---
# Inlined into the bundle when `docker compose build` runs (Vite is build-time,
# not runtime). Must match the URL the user's browser will actually use to
# reach the backend — i.e. the public domain hitting the host reverse proxy,
# NOT the internal Docker hostname.
#
# If the frontend nginx proxies /api/ on the same domain as the SPA (default
# in frontend/nginx.conf), a relative path also works and is recommended:
# VITE_API_BASE_URL=/api
#
# If using a separate API domain, use the absolute public URL instead:
# VITE_API_BASE_URL=https://your-domain.example/api
