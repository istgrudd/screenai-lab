# === Application ===
ENVIRONMENT=development
APP_PORT=8000

# === DeepSeek LLM ===
DEEPSEEK_API_KEY=sk-xxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# === Database ===
# Local dev (SQLite):
DATABASE_URL=sqlite:///./data/app.db
# Production (Railway PostgreSQL) — Railway injects this automatically when
# you attach a Postgres plugin. Legacy "postgres://" is normalized by the app.
# DATABASE_URL=postgresql://user:password@host:5432/screenai_lab

# === Vector Store ===
CHROMA_PERSIST_DIR=./backend/vectorstore

# === NER Model ===
NER_MODEL_NAME=ageng-anugrah/indobert-large-p2-finetuned-ner

# === Embedding Model ===
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# === Frontend / CORS ===
# Single origin (used when ALLOWED_ORIGINS is empty):
FRONTEND_URL=http://localhost:5173
# Comma-separated list for production (takes precedence when non-empty):
# ALLOWED_ORIGINS=https://screenai-lab.vercel.app,https://www.screenai-lab.app

# === Auth ===
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=dev-secret-change-me-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# === Frontend (Vite) ===
# Base URL for the backend API the browser talks to. Required for any
# non-local deployment — production builds embed this value at build
# time. Falls back to http://127.0.0.1:8000/api when unset.
# Example (prod): VITE_API_BASE_URL=https://screenai-api.example.com/api
VITE_API_BASE_URL=http://127.0.0.1:8000/api

# === Recruitment Period ===
# Exposed to the frontend via Vite (must start with VITE_). Candidate
# dashboard uses this for the countdown timer. ISO 8601, local time.
VITE_RECRUITMENT_DEADLINE=2026-05-31T23:59:59
